local Tabs = {}
local function AddTab(name)
    local btn = Instance.new("TextButton", TabContainer)
    btn.Size = UDim2.new(1, -6, 0, 32)
    btn.Position = UDim2.new(0, 3, 0, 4 + (#Tabs) * 36)
    btn.BackgroundTransparency = 1
    btn.Text = "  " .. name
    btn.TextColor3 = Color3.fromRGB(150,150,170)
    btn.TextSize = 13
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Font = Enum.Font.Gotham
    
    local content = Instance.new("Frame", ContentArea)
    content.Size = UDim2.new(1, -6, 0, 0)
    content.Position = UDim2.new(0, 3, 0, 0)
    content.BackgroundTransparency = 1
    content.Visible = false
    local lay = Instance.new("UIListLayout", content)
    lay.Padding = UDim.new(0, 4)
    lay.SortOrder = Enum.SortOrder.LayoutOrder
    Instance.new("UIPadding", content).PaddingLeft = UDim.new(0, 4)
    
    btn.MouseButton1Click:Connect(function()
        for _, t in pairs(Tabs) do t.btn.BackgroundTransparency = 1; t.btn.TextColor3 = Color3.fromRGB(150,150,170); t.content.Visible = false end
        btn.BackgroundTransparency = 0.85; btn.BackgroundColor3 = Color3.fromRGB(0,170,255); btn.TextColor3 = Color3.new(1,1,1)
        content.Visible = true
    end)
    
    table.insert(Tabs, {btn = btn, content = content})
    if #Tabs == 1 then btn.BackgroundTransparency = 0.85; btn.BackgroundColor3 = Color3.fromRGB(0,170,255); btn.TextColor3 = Color3.new(1,1,1); content.Visible = true end
    return content
end

