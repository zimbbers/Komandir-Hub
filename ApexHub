-- ==================== ESP ====================

local function createESP(obj, color, text)
    if not obj or not obj.Parent then return end
    local highlight = Instance.new("Highlight")
    highlight.FillColor = color
    highlight.OutlineColor = Color3.new(1,1,1)
    highlight.FillTransparency = 0.5
    highlight.Adornee = obj
    highlight.Parent = obj
    ESPObjects[obj] = highlight
end

local function updateESP()
    for _, v in pairs(ESPObjects) do
        if v and v.Adornee and v.Adornee.Parent then
            -- already exists
        else
            if v then v:Destroy() end
            ESPObjects[_] = nil
        end
    end
    if Toggles.ESPPlayers then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and not ESPObjects[player.Character] then
                createESP(player.Character, Color3.new(1,0,0), player.Name)
            end
        end
    end
    if Toggles.ESPMobs then
        for _, mob in pairs(workspace.Enemies:GetChildren()) do
            if not ESPObjects[mob] then
                createESP(mob, Color3.new(1,1,0), "Mob")
            end
        end
    end
    -- фрукты и сундуки можно добавить по аналогии
end

