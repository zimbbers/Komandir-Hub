local function Tog(parent, label, section, key, y)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, 260, 0, 28)
    bg.Position = UDim2.new(0, 10, 0, y)
    bg.BackgroundTransparency = 1
    bg.Parent = parent
    
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0, 180, 1, 0)
    lbl.Text = label
    lbl.TextColor3 = CI(200, 200, 200)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = bg
    
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0, 55, 0, 22)
    b.Position = UDim2.new(0, 190, 0.5, -11)
    b.Text = Config[section][key] and "ON" or "OFF"
    b.TextColor3 = Config[section][key] and CI(0, 255, 100) or CI(255, 50, 50)
    b.BackgroundColor3 = CI(40, 40, 55)
    b.BorderSizePixel = 0
    b.Font = Enum.Font.GothamBold
    b.TextSize = 11
    b.Parent = bg
    
    b.MouseButton1Click:Connect(function()
        Config[section][key] = not Config[section][key]
        b.Text = Config[section][key] and "ON" or "OFF"
        b.TextColor3 = Config[section][key] and CI(0, 255, 100) or CI(255, 50, 50)
    end)
    return bg
end

local function Slider(parent, label, section, key, mn, mx, y)
