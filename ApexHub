local function AddToggle(parent, label, section, key, y)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, 250, 0, 26)
    bg.Position = UDim2.new(0, 10, 0, y)
    bg.BackgroundTransparency = 1
    bg.Parent = parent
    
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(0, 175, 1, 0)
    l.Text = label
    l.TextColor3 = Color3.fromRGB(200, 200, 200)
    l.BackgroundTransparency = 1
    l.Font = Enum.Font.Gotham
    l.TextSize = 13
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.Parent = bg
    
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0, 50, 0, 20)
    b.Position = UDim2.new(0, 185, 0.5, -10)
    b.Text = Settings[section][key] and "ON" or "OFF"
    b.TextColor3 = Settings[section][key] and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 50, 50)
    b.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
    b.BorderSizePixel = 0
    b.Font = Enum.Font.GothamBold
    b.TextSize = 11
    b.Parent = bg
    
    b.MouseButton1Click:Connect(function()
        Settings[section][key] = not Settings[section][key]
        b.Text = Settings[section][key] and "ON" or "OFF"
        b.TextColor3 = Settings[section][key] and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 50, 50)
    end)
    return 28
end

local function AddSlider(parent, label, section, key, mn, mx, y)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, 250, 0, 26)
    bg.Position = UDim2.new(0, 10, 0, y)
    bg.BackgroundTransparency = 1
    bg.Parent = parent
    
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(0, 130, 1, 0)
    l.Text = label
    l.TextColor3 = Color3.fromRGB(200, 200, 200)
    l.BackgroundTransparency = 1
    l.Font = Enum.Font.Gotham
    l.TextSize = 13
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.Parent = bg
    
    local vl = Instance.new("TextLabel")
    vl.Size = UDim2.new(0, 35, 1, 0)
    vl.Position = UDim2.new(0, 135, 0, 0)
    vl.Text = tostring(Settings[section][key])
    vl.TextColor3 = Color3.fromRGB(0, 200, 255)
    vl.BackgroundTransparency = 1
    vl.Font = Enum.Font.Gotham
    vl.TextSize = 12
    vl.Parent = bg
    
    local sb = Instance.new("Frame")
    sb.Size = UDim2.new(0, 70, 0, 5)
    sb.Position = UDim2.new(0, 175, 0.5, -2.5)
    sb.BackgroundColor3 = Color3.fromRGB(45, 45, 60)
    sb.BorderSizePixel = 0
    sb.Parent = bg
    
    local sf = Instance.new("Frame")
    sf.Size = UDim2.new((Settings[section][key]-mn)/(mx-mn), 0, 1, 0)
    sf.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
    sf.BorderSizePixel = 0
    sf.Parent = sb
    
    local drag = false
    sb.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true end
    end)
    sb.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
    end)
    
    RS.RenderStepped:Connect(function()
        if drag then
            local pos = UIS:GetMouseLocation()
            local ap = sb.AbsolutePosition
            local as = sb.AbsoluteSize
            local rel = math.clamp((pos.X - ap.X) / as.X, 0, 1)
            local val = math.floor(mn + (mx-mn) * rel)
            Settings[section][key] = val
            vl.Text = tostring(val)
            sf.Size = UDim2.new(rel, 0, 1, 0)
        end
    end)
    return 28
end

