RunService.RenderStepped:Connect(function()
    if ApexHub.Flags["Toggle_Aimbot"] and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local Target = GetClosest()
        if Target and Target.Character and Target.Character:FindFirstChild(C.Aim.Part) then
            local tp = Target.Character[C.Aim.Part].Position
            Camera.CFrame = Camera.CFrame:Lerp(
                CFrame.new(Camera.CFrame.Position, tp),
                C.Aim.Smooth
            )
        end
    end
end)

-- ============================================
-- ESP
-- ============================================
local ESP_Drawings = {}

local function EnsureESP(p)
    if not ESP_Drawings[p] then
        ESP_Drawings[p] = {
            Box = Drawing.new("Square"),
            Health = Drawing.new("Square"),
            Name = Drawing.new("Text"),
            Tracer = Drawing.new("Line")
        }
        ESP_Drawings[p].Box.Thickness = 2; ESP_Drawings[p].Box.Filled = false
        ESP_Drawings[p].Health.Filled = true
        ESP_Drawings[p].Name.Size = 13; ESP_Drawings[p].Name.Center = true; ESP_Drawings[p].Name.Outline = true
        ESP_Drawings[p].Tracer.Thickness = 1
    end
    return ESP_Drawings[p]
end

RunService.RenderStepped:Connect(function()
    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local d = EnsureESP(p)
        local char = p.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        local show = false
        
        if root and hum and hum.Health > 0 then
            if C.ESP.TeamCheck and p.Team == LocalPlayer.Team then
                -- skip
            else
                local hp = char.Head.Position
                local sp, on = Camera:WorldToViewportPoint(hp)
                if on then
                    show = true
                    local scale = (Camera.CFrame.Position - root.Position).Magnitude / 500
                    local sz = Vector2.new(40/scale, 60/scale)
                    
                    if ApexHub.Flags["Toggle_Box"] then
                        d.Box.Size = sz
                        d.Box.Position = Vector2.new(sp.X - sz.X/2, sp.Y - sz.Y/2)
                        d.Box.Color = Color3.fromRGB(0, 255, 0)
                        d.Box.Visible = true
                    else d.Box.Visible = false end
                    
                    if ApexHub.Flags["Toggle_Health"] and hum then
                        local hpct = hum.Health / hum.MaxHealth
                        d.Health.Size = Vector2.new(4, 60/scale)
                        d.Health.Position = Vector2.new(sp.X + sz.X/2 + 3, sp.Y - 30/scale)
                        d.Health.Color = Color3.fromRGB(255*(1-hpct), 255*hpct, 0)
                        d.Health.Visible = true
                    else d.Health.Visible = false end
                    
                    if ApexHub.Flags["Toggle_Name"] then
                        d.Name.Position = Vector2.new(sp.X, sp.Y - sz.Y/2 - 15)
                        d.Name.Text = p.Name
                        d.Name.Color = Color3.new(1,1,1)
                        d.Name.Visible = true
                    else d.Name.Visible = false end
                    
                    if ApexHub.Flags["Toggle_Tracer"] then
                        d.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                        d.Tracer.To = Vector2.new(sp.X, sp.Y)
                        d.Tracer.Color = Color3.new(1,1,1)
                        d.Tracer.Visible = true
                    else d.Tracer.Visible = false end
                end
            end
        end
        
        if not show then
            d.Box.Visible = false; d.Health.Visible = false
            d.Name.Visible = false; d.Tracer.Visible = false
        end
    end
end)

