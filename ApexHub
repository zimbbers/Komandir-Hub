-- SKIN CHANGER
-- ============================================
local SkinChanger = {}
SkinChanger.CurrentSkin = nil
SkinChanger.Originals = {}

SkinChanger.Skins = {
    ["AK-47"] = {"Dragon Lore", "Fire Serpent", "Vulcan", "Redline", "Default"},
    ["M4A1"] = {"Dragon King", "Howl", "Neo-Noir", "Decimator", "Default"},
    ["AWP"] = {"Dragon Lore AWP", "Medusa", "Oni Taiji", "Electric Hive", "Default"},
    ["Deagle"] = {"Blaze", "Printstream", "Code Red", "Conspiracy", "Default"},
    ["Knife"] = {"Karambit Fade", "Butterfly Fade", "M9 Bayonet", "Flip Knife", "Default"}
}

local function ApplySkin(tool)
    if not tool or not tool:IsA("Tool") then return end
    if not SkinChanger.Originals[tool] then
        local h = tool:FindFirstChild("Handle")
        if h then
            SkinChanger.Originals[tool] = { Color = h.Color, Material = h.Material, Trans = h.Transparency }
        end
    end
    
    -- Highlight
    local hl = tool:FindFirstChild("_SkinHL")
    if not hl then
        hl = Instance.new("Highlight")
        hl.Name = "_SkinHL"
        hl.FillColor = Color3.fromRGB(255, 215, 0)
        hl.FillTransparency = 0.5
        hl.OutlineColor = Color3.new(1,1,1)
        hl.OutlineTransparency = 0.7
        hl.Parent = tool
    end
    hl.Enabled = true
    
    local h = tool:FindFirstChild("Handle")
    if h then
        h.Color = Color3.fromRGB(255, 200, 50)
        h.Material = Enum.Material.ForceField
    end
    for _, c in pairs(tool:GetDescendants()) do
        if c:IsA("MeshPart") then
            c.Color = Color3.fromRGB(255, 200, 50)
            c.Material = Enum.Material.ForceField
        end
    end
end

function SkinChanger.Apply()
    if LocalPlayer.Character then
        for _, t in pairs(LocalPlayer.Character:GetChildren()) do
            if t:IsA("Tool") then ApplySkin(t) end
        end
    end
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, t in pairs(bp:GetChildren()) do
            if t:IsA("Tool") then ApplySkin(t) end
        end
    end
    warn("[ApexHub] Skin applied (local)")
end

function SkinChanger.Reset()
    if LocalPlayer.Character then
        for _, t in pairs(LocalPlayer.Character:GetChildren()) do
            if t:IsA("Tool") then
                local hl = t:FindFirstChild("_SkinHL")
                if hl then hl:Destroy() end
                local h = t:FindFirstChild("Handle")
                if h and SkinChanger.Originals[t] then
                    h.Color = SkinChanger.Originals[t].Color
                    h.Material = SkinChanger.Originals[t].Material
                    h.Transparency = SkinChanger.Originals[t].Trans
                end
            end
        end
    end
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, t in pairs(bp:GetChildren()) do
            if t:IsA("Tool") then
                local hl = t:FindFirstChild("_SkinHL")
                if hl then hl:Destroy() end
                local h = t:FindFirstChild("Handle")
                if h and SkinChanger.Originals[t] then
                    h.Color = SkinChanger.Originals[t].Color
                    h.Material = SkinChanger.Originals[t].Material
                    h.Transparency = SkinChanger.Originals[t].Trans
                end
            end
        end
    end
    SkinChanger.Originals = {}
    warn("[ApexHub] Skin reset")
end

