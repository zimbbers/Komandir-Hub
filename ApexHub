local function UpdateESP()
    for player, esp in pairs(espObjects) do
        if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            if esp.Box then esp.Box.Visible = false end
            if esp.Billboard then esp.Billboard.Enabled = false end
            continue
        end
        
        local character = player.Character
        local humanoid = character:FindFirstChild("Humanoid")
        local root = character.HumanoidRootPart
        
        if humanoid and humanoid.Health > 0 and Settings.ESP.Enabled then
            -- Update Box
            if esp.Box then
                esp.Box.Adornee = root
                esp.Box.Color3 = Settings.ESP.BoxColor
                esp.Box.Visible = Settings.ESP.Box
                if esp.Box.Parent == nil then
                    esp.Box.Parent = root
                end
            end
            
            -- Update Billboard
            if esp.Billboard then
                if Settings.ESP.Name then
                    local teamColor = player.Team and player.Team.TeamColor.Color or Color3.fromRGB(255, 255, 255)
                    esp.NameLabel.Text = player.Name
                    esp.NameLabel.TextColor3 = Settings.ESP.TeamColor and teamColor or Color3.fromRGB(255, 255, 255)
                else
                    esp.NameLabel.Text = ""
                end
                
                local healthPercent = humanoid.Health / humanoid.MaxHealth
                esp.HealthBar.Size = UDim2.new(0, math.clamp(100 * healthPercent, 0, 100), 0, 4)
                esp.HealthBar.BackgroundColor3 = Color3.fromRGB(255 * (1 - healthPercent), 255 * healthPercent, 0)
                esp.HealthBar.Visible = Settings.ESP.HealthBar
                
                if Settings.ESP.Weapon then
                    local tool = character:FindFirstChildOfClass("Tool")
                    esp.WeaponLabel.Text = tool and tool.Name or "None"
                else
                    esp.WeaponLabel.Text = ""
                end
                
                if Settings.ESP.Distance then
                    local dist = math.floor((root.Position - Camera.CFrame.Position).Magnitude)
                    esp.DistLabel.Text = dist .. " studs"
                else
                    esp.DistLabel.Text = ""
                end
                
                esp.Billboard.Enabled = true
                if esp.Billboard.Parent == nil then
                    esp.Billboard.Parent = root
                end
            end
        else
            if esp.Box then esp.Box.Visible = false end
            if esp.Billboard then esp.Billboard.Enabled = false end
        end
    end
end

-- ========== SKIN CHANGER ==========
local function ApplySkinChanger()
    if not Settings.SkinChanger.Enabled then return end
    
    local character = Player.Character
    if not character then return end
    
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") then
            local weaponName = tool.Name
            local skinName = Settings.SkinChanger.WeaponSkins[weaponName]
            if skinName then
                -- Поиск текстурки/меша для замены
                local handle = tool:FindFirstChild("Handle")
                if handle then
                    -- Применяем цвет/материал под скин
                    -- (в реальном скрипте будет полноценный поиск по ID скина)
                    local success, err = pcall(function()
                        -- Пример: меняем цвет через Mesh/Texture
                        local mesh = handle:FindFirstChild("Mesh")
                        if mesh then
                            mesh.VertexColor = Vector3.new(
                                math.random(50, 255) / 255,
                                math.random(50, 255) / 255,
                                math.random(50, 255) / 255
                            )
                        end
                    end)
                end
            end
        end
    end
end

-- ========== NO RECOIL ==========
local function ApplyNoRecoil()
    if not Settings.Visuals.NoRecoil then return end
    
    local character = Player.Character
    if not character then return end
    
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") then
            for _, script in ipairs(tool:GetDescendants()) do
                if script:IsA("LocalScript") and script:FindFirstChild("GunScript") then
                    -- Override recoil
                    pcall(function()
                        script.Disabled = true
                        script.Disabled = false
                    end)
                end
            end
        end
    end
end

