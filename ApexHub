        end
        local d = ESP[p]; local c = p.Character; local r = c and c:FindFirstChild("HumanoidRootPart"); local h = c and c:FindFirstChild("Humanoid")
        local show = false
        if r and h and h.Health > 0 then
            if CF.ESPTeam and p.Team == LP.Team then
            else
                local sp, on = Camera:WorldToViewportPoint(c.Head.Position)
                if on then
                    show = true; local s = (Camera.CFrame.Position - r.Position).Magnitude / 500
                    local sz = Vector2.new(40/s, 60/s)
                    if _G.A_Box then d.Box.Size = sz; d.Box.Position = Vector2.new(sp.X - sz.X/2, sp.Y - sz.Y/2); d.Box.Color = Color3.fromRGB(0,255,0); d.Box.Visible = true else d.Box.Visible = false end
                    if _G.A_Health and h then local hp = h.Health / h.MaxHealth; d.Health.Size = Vector2.new(4, 60/s); d.Health.Position = Vector2.new(sp.X + sz.X/2 + 3, sp.Y - 30/s); d.Health.Color = Color3.fromRGB(255*(1-hp), 255*hp, 0); d.Health.Visible = true else d.Health.Visible = false end
                    if _G.A_Name then d.Name.Position = Vector2.new(sp.X, sp.Y - sz.Y/2 - 15); d.Name.Text = p.Name; d.Name.Color = Color3.new(1,1,1); d.Name.Visible = true else d.Name.Visible = false end
