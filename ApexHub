-- ============================================
-- ПОИСК БЛИЖАЙШЕГО
-- ============================================
local function GetClosest()
    local Closest, Shortest = nil, C.Aim.FOV
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
            if C.Aim.TeamCheck and p.Team == LocalPlayer.Team then continue end
            local sp, on = Camera:WorldToViewportPoint(p.Character.Head.Position)
            if not on then continue end
            local mp = UserInputService:GetMouseLocation()
            local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
            if d < Shortest then Shortest = d; Closest = p end
        end
    end
    return Closest
end

