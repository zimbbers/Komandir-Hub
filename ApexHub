local function UpdateESP()
    for plr, obj in pairs(ESP) do
        local root = IsAlive(plr)
        if root and Settings.ESP.Enabled then
            obj.BB.Enabled = true
            obj.BB.Parent = root
            
            local hum = plr.Character.Humanoid
            local hp = hum.Health / hum.MaxHealth
            
            obj.Name.Text = Settings.ESP.Name and plr.Name or ""
            obj.Name.TextColor3 = Settings.ESP.Color
            
            obj.HP.Size = UDim2.new(hp, 0, 1, 0)
            obj.HP.BackgroundColor3 = Color3.fromRGB(255 * (1 - hp), 255 * hp, 0)
            obj.HP.Parent.Visible = Settings.ESP.Health
            
            local tool = plr.Character:FindFirstChildOfClass("Tool")
            obj.WP.Text = Settings.ESP.Weapon and (tool and tool.Name or "No weapon") or ""
            
            local dist = math.floor((root.Position - Cam.CFrame.Position).Magnitude)
            obj.Dist.Text = Settings.ESP.Dist and (dist .. " studs") or ""
        else
            obj.BB.Enabled = false
        end
    end
end

-- ====== SKIN CHANGER ======
local function ApplySkins()
    if not Settings.Skins.Enabled then return end
    local c = LP.Character
    if not c then return end
    
    for _, tool in ipairs(c:GetChildren()) do
        if tool:IsA("Tool") then
            local skin = Settings.Skins[tool.Name]
            if skin then
                local handle = tool:FindFirstChild("Handle")
                if handle then
                    pcall(function()
                        local mesh = handle:FindFirstChildOfClass("SpecialMesh")
                        if mesh then
                            -- Клиент-сайд: меняем цвет под скин
                            local seed = 0
                            for i = 1, #skin do seed = seed + string.byte(skin, i) end
                            local r = ((seed * 3) % 155 + 100) / 255
                            local g = ((seed * 7) % 155 + 100) / 255
                            local b = ((seed * 11) % 155 + 100) / 255
                            mesh.VertexColor = Vector3.new(r, g, b)
                        end
                    end)
                end
            end
        end
    end
end

-- ====== NO RECOIL ======
local function NoRecoil()
    if not Settings.Visuals.NoRecoil then return end
    local tool = GetTool()
    if not tool then return end
    
    for _, s in ipairs(tool:GetDescendants()) do
        if s:IsA("LocalScript") then
            pcall(function()
                s.Disabled = true
                task.wait()
                s.Disabled = false
            end)
        end
    end
end

-- ====== BUNNY HOP ======
local function BunnyHop()
    if not Settings.Visuals.BHop then return end
    local c = LP.Character
    if not c then return end
    local h = c:FindFirstChild("Humanoid")
    if h and h.FloorMaterial ~= Enum.Material.Air and UIS:IsKeyDown(Enum.KeyCode.Space) then
        h:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end

-- ====== ANTI FLASH ======
local function AntiFlash()
    if not Settings.Misc.AntiFlash then return end
    pcall(function()
        local f = LP.PlayerGui:FindFirstChild("FlashScreen") or LP.PlayerGui:FindFirstChild("Flash")
        if f then f.Enabled = false end
    end)
end

