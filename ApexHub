-- ====== ФУНКЦИИ ======
local function IsAlive(plr)
    local c = plr.Character
    if not c then return false end
    local h = c:FindFirstChild("Humanoid")
    local r = c:FindFirstChild("HumanoidRootPart")
    return h and r and h.Health > 0 and r
end

local function GetTool()
    local c = LP.Character
    if not c then return nil end
    return c:FindFirstChildOfClass("Tool")
end

-- ====== AIMBOT CORE ======
local function GetTarget()
    local closest, closestDist = nil, Settings.Aimbot.FOV
    local mPos = UIS:GetMouseLocation()
    
    for _, plr in ipairs(P:GetPlayers()) do
        if plr == LP then continue end
        local root = IsAlive(plr)
        if not root then continue end
        
        if Settings.Aimbot.TeamCheck and plr.Team == LP.Team then continue end
        
        if Settings.Aimbot.WallCheck then
            local ray = Ray.new(Cam.CFrame.Position, (root.Position - Cam.CFrame.Position).Unit * 1000)
            local hit = WS:FindPartOnRayWithIgnoreList(ray, {LP.Character})
            if hit and not hit:IsDescendantOf(plr.Character) then continue end
        end
        
        local sp, onSc = Cam:WorldToViewportPoint(root.Position)
        if onSc then
            local dist = (Vector2.new(sp.X, sp.Y) - mPos).Magnitude
            if dist < closestDist then
                closestDist = dist
                closest = plr
            end
        end
    end
    return closest
end

-- ====== AIMBOT EXECUTION ======
local function DoAimbot()
    if not Settings.Aimbot.Enabled then return end
    local target = GetTarget()
    if not target then return end
    
    local root = IsAlive(target)
    if not root then return end
    
    local part = target.Character:FindFirstChild(Settings.Aimbot.Target)
    if not part then part = root end
    
    if Settings.Aimbot.Silent then
        -- Silent Aim: меняем CFrame камеры для выстрела
        local sp = Cam:WorldToViewportPoint(part.Position)
        -- В реальном скрипте здесь mousemoverel или CFrame
    else
        -- Legit Aim: плавный поворот
        local tCF = CFrame.new(Cam.CFrame.Position, part.Position)
        Cam.CFrame = Cam.CFrame:Lerp(tCF, Settings.Aimbot.Smooth / 100, 0.3)
    end
    
    -- Стреляем если Rage Mode
    if Settings.Aimbot.Rage then
        local tool = GetTool()
        if tool then
            for _, ev in ipairs(tool:GetDescendants()) do
                if ev:IsA("RemoteEvent") then
                    pcall(function()
                        ev:FireServer("Shoot", part.Position)
                    end)
                    break
                end
            end
        end
    end
end

