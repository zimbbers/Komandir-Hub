local function BypassAnticheat()
    -- Hyperion / BYSON bypass attempt
    pcall(function()
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        local oldIndex = mt.__index
        mt.__index = function(self, key)
            if key == "detectInjector" or key == "isExploit" or key == "isRunning" then
                return function() return false end
            end
            return oldIndex(self, key)
        end
        setreadonly(mt, true)
    end)
    
    -- Блокировка HTTP к античиту
    pcall(function()
        local oldRequest = syn.request or http_request or request
        if oldRequest then
            syn.request = function(...)
                local args = {...}
                if type(args) == "table" and args.Url then
                    if args.Url:lower():find("anticheat") or args.Url:lower():find("ban") or args.Url:lower():find("analytics") then
                        return { StatusCode = 200, Body = "{}", Headers = {} }
                    end
                end
                return oldRequest(...)
            end
        end
    end)
    
    print("[+] Anticheat bypass attempted")
end

