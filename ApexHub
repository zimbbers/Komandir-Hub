-- ===== AUTO FARM LEVELS/QUESTS/BOSSES (Redz Hub) =====
local function AutoFarmLevels()
   Connections.AutoFarm = RunService.Heartbeat:Connect(function()
      if not Toggles.AutoFarmLevels then return end
      -- Find nearest mob
      local mob = workspace.Enemies:FindFirstChildOfClass("Model")
      if mob and mob:FindFirstChild("HumanoidRootPart") then
         LocalPlayer.Character.HumanoidRootPart.CFrame = mob.HumanoidRootPart.CFrame * CFrame.new(0, 10, 0)
         mob.Humanoid.Health = 0  -- Simulate damage (adapt remote)
      end
   end)
end

