local function takeQuest()
    -- Поиск NPC с меткой "!" (обычно это квестодатель)
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Part") and v.Name == "Part" and v.Parent and v.Parent:FindFirstChild("Head") and v.Parent:FindFirstChild("Humanoid") then
            local npc = v.Parent
            if npc:FindFirstChild("Dialog") or npc:FindFirstChild("ClickDetector") then
                -- Подойдём к NPC
                local hrp = getHRP()
                if hrp then
                    hrp.CFrame = npc.HumanoidRootPart.CFrame * CFrame.new(0, 0, 5)
                    task.wait(0.5)
                    -- Активируем диалог (например, через ClickDetector)
                    local cd = npc:FindFirstChildOfClass("ClickDetector")
                    if cd then
                        fireclickdetector(cd)
                    end
                    -- Выбираем первый вариант (обычно "Take Quest")
                    task.wait(0.5)
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
                end
                break
            end
        end
    end
end

