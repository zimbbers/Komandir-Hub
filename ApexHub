-- === FUNCTIONS ===
local function closest(fov)
    local best, short = nil, fov or 360
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("Head") then
            if CF.Team and p.Team == LP.Team then continue end
            local sp, on = Camera:WorldToViewportPoint(p.Character.Head.Position)
            if not on then continue end
            local mp = UIS:GetMouseLocation()
            local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
            if d < short then short = d; best = p end
        end
    end
    return best
end

-- Silent remote search
local sRemote = nil
for _, o in pairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
    if o:IsA("RemoteEvent") then
        local n = o.Name:lower()
        if n:find("fire") or n:find("shoot") or n:find("bullet") then sRemote = o; break end
    end
end

-- AIMBOT
RunSvc.RenderStepped:Connect(function()
    if _G.A_Aim and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local target = closest(CF.FOV)
        if target and target.Character and target.Character:FindFirstChild(CF.Part) then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Character[CF.Part].Position), CF.Smooth)
        end
    end
end)

-- SILENT AIM
if sRemote then
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    local oldNC = mt.__namecall
    mt.__namecall = function(self, ...)
        local m = getnamecallmethod()
        local a = {...}
        if m == "FireServer" and self == sRemote and _G.A_Silent then
            local target = closest(360)
            if target and target.Character and target.Character:FindFirstChild(CF.Part) then
                a[#a] = (target.Character[CF.Part].Position - LP.Character.Head.Position).Unit
                return oldNC(self, unpack(a))
            end
        end
        return oldNC(self, ...)
    end
    setreadonly(mt, true)
end

-- TRIGGERBOT
RunSvc.RenderStepped:Connect(function()
    if _G.A_Trig then
        local t = Mouse.Target
        if t then
            local p = Players:GetPlayerFromCharacter(t.Parent)
            if not p then p = Players:GetPlayerFromCharacter(t.Parent and t.Parent.Parent) end
            if p and p ~= LP then
                if CF.Team and p.Team == LP.Team then return end
                if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                    if (t.Position - LP.Character.HumanoidRootPart.Position).Magnitude <= CF.TrigD then
                        mouse1click(); task.wait(CF.TrigR)
                    end
                end
            end
        end
    end
end)

