local function ApplySkinToTool(Tool)
    if not Tool or not Tool:IsA("Tool") then return end
    
    -- Сохраняем оригинал
    if not OriginalAccessories[Tool] then
        local Handle = Tool:FindFirstChild("Handle")
        if Handle then
            OriginalAccessories[Tool] = {
                Color = Handle.Color or Color3.new(1,1,1),
                Material = Handle.Material or Enum.Material.Plastic,
                Transparency = Handle.Transparency or 0
            }
        end
    end
    
    -- Применяем Highlight
    local Highlight = Tool:FindFirstChild("SkinHL")
    if not Highlight then
        Highlight = Instance.new("Highlight")
        Highlight.Name = "SkinHL"
        Highlight.FillColor = Color3.fromRGB(255, 215, 0)
        Highlight.FillTransparency = 0.6
        Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        Highlight.OutlineTransparency = 0.8
        Highlight.Parent = Tool
    end
    Highlight.Enabled = true
    
    -- Меняем цвет Handle
    local Handle = Tool:FindFirstChild("Handle")
    if Handle then
        Handle.Color = Color3.fromRGB(255, 200, 50)
        Handle.Material = Enum.Material.ForceField
    end
    
    -- Меняем все MeshPart
    for _, child in pairs(Tool:GetDescendants()) do
        if child:IsA("MeshPart") then
            child.Color = Color3.fromRGB(255, 200, 50)
            child.Material = Enum.Material.ForceField
        end
    end
end

function SkinChanger.ApplySkin(WeaponCategory, SkinData)
    if not WeaponCategory or not SkinData then return end
    CurrentSkin = SkinData
    
    -- Применяем к текущему оружию
    if LocalPlayer.Character then
        for _, Tool in pairs(LocalPlayer.Character:GetChildren()) do
            if Tool:IsA("Tool") then
                ApplySkinToTool(Tool)
            end
        end
    end
    
    -- Применяем к инвентарю
    local Backpack = LocalPlayer:FindFirstChild("Backpack")
    if Backpack then
        for _, Tool in pairs(Backpack:GetChildren()) do
            if Tool:IsA("Tool") then
                ApplySkinToTool(Tool)
            end
        end
    end
    
    -- Пробуем найти и эксплуатировать RemoteEvent скина
    local SkinRemote = nil
    for _, obj in pairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            local n = obj.Name:lower()
            if n:find("skin") or n:find("equip") or n:find("cosmetic") or n:find("apply") then
                SkinRemote = obj
                break
            end
        end
    end
    
    if SkinRemote then
        pcall(function()
            SkinRemote:FireServer(SkinData.Name, SkinData.AssetId)
        end)
        pcall(function()
            SkinRemote:FireServer(WeaponCategory, SkinData.Name)
        end)
        pcall(function()
            SkinRemote:FireServer(LocalPlayer.UserId, SkinData.AssetId)
        end)
    end
    
    print("[SkinChanger] Applied:", SkinData.Name)
end

function SkinChanger.ResetSkin()
    if LocalPlayer.Character then
        for _, Tool in pairs(LocalPlayer.Character:GetChildren()) do
            if Tool:IsA("Tool") then
                local hl = Tool:FindFirstChild("SkinHL")
                if hl then hl:Destroy() end
                
                local Handle = Tool:FindFirstChild("Handle")
                if Handle and OriginalAccessories[Tool] then
                    Handle.Color = OriginalAccessories[Tool].Color
                    Handle.Material = OriginalAccessories[Tool].Material
                    Handle.Transparency = OriginalAccessories[Tool].Transparency
                end
            end
        end
    end
    
    local Backpack = LocalPlayer:FindFirstChild("Backpack")
    if Backpack then
        for _, Tool in pairs(Backpack:GetChildren()) do
            if Tool:IsA("Tool") then
                local hl = Tool:FindFirstChild("SkinHL")
                if hl then hl:Destroy() end
                
                local Handle = Tool:FindFirstChild("Handle")
                if Handle and OriginalAccessories[Tool] then
                    Handle.Color = OriginalAccessories[Tool].Color
                    Handle.Material = OriginalAccessories[Tool].Material
                    Handle.Transparency = OriginalAccessories[Tool].Transparency
                end
            end
        end
    end
    
    OriginalAccessories = {}
    CurrentSkin = nil
    print("[SkinChanger] Reset")
end

