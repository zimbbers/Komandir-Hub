-- Toggle
function ApexHub:Toggle(Parent, Name, Default, Callback)
    local Flag = "Toggle_" .. Name
    ApexHub.Flags[Flag] = Default or false
    
    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(1, -8, 0, 32)
    Frame.BackgroundColor3 = ApexHub.Theme.Button
    Frame.BackgroundTransparency = 0.3
    
    local F_Corner = Instance.new("UICorner")
    F_Corner.CornerRadius = UDim.new(0, 4)
    F_Corner.Parent = Frame
    
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, -50, 1, 0)
    Label.Position = UDim2.new(0, 10, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = Name
    Label.TextColor3 = ApexHub.Theme.Text
    Label.TextSize = 13
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Font = Enum.Font.Gotham
    Label.Parent = Frame
    
    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Size = UDim2.new(0, 38, 0, 22)
    ToggleBtn.Position = UDim2.new(1, -46, 0, 5)
    ToggleBtn.BackgroundColor3 = Default and ApexHub.Theme.ToggleOn or ApexHub.Theme.ToggleOff
    ToggleBtn.Text = ""
    ToggleBtn.AutoButtonColor = false
    
    local T_Corner = Instance.new("UICorner")
    T_Corner.CornerRadius = UDim.new(0, 11)
    T_Corner.Parent = ToggleBtn
    
    local ToggleCircle = Instance.new("Frame")
    ToggleCircle.Size = UDim2.new(0, 16, 0, 16)
    ToggleCircle.Position = Default and UDim2.new(1, -20, 0, 3) or UDim2.new(0, 3, 0, 3)
    ToggleCircle.BackgroundColor3 = Color3.new(1, 1, 1)
    
    local TC_Corner = Instance.new("UICorner")
    TC_Corner.CornerRadius = UDim.new(0, 8)
    TC_Corner.Parent = ToggleCircle
    ToggleCircle.Parent = ToggleBtn
    
    ToggleBtn.MouseButton1Click:Connect(function()
        ApexHub.Flags[Flag] = not ApexHub.Flags[Flag]
        ToggleBtn.BackgroundColor3 = ApexHub.Flags[Flag] and ApexHub.Theme.ToggleOn or ApexHub.Theme.ToggleOff
        ToggleCircle:TweenPosition(
            ApexHub.Flags[Flag] and UDim2.new(1, -20, 0, 3) or UDim2.new(0, 3, 0, 3),
            Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.15, true
        )
        pcall(Callback, ApexHub.Flags[Flag])
    end)
    
    ToggleBtn.Parent = Frame
    Frame.Parent = Parent
    
    return Frame
end

-- Slider
function ApexHub:Slider(Parent, Name, Min, Max, Default, Callback, Suffix)
    Suffix = Suffix or ""
