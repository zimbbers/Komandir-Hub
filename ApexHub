    bg.Size = UDim2.new(1, -16, 0, 6); bg.Position = UDim2.new(0, 8, 0, 30); bg.BackgroundColor3 = Color3.fromRGB(60,60,80)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 3)
    local fl = Instance.new("Frame", bg)
    local pct = (def - min) / (max - min); fl.Size = UDim2.new(pct, 0, 1, 0); fl.BackgroundColor3 = Color3.fromRGB(0,170,255)
    Instance.new("UICorner", fl).CornerRadius = UDim.new(0, 3)
    local ht = Instance.new("TextButton", bg); ht.Size = UDim2.new(1, 0, 1, 0); ht.BackgroundTransparency = 1; ht.Text = ""
    local dr = false; local cv = def
    ht.MouseButton1Down:Connect(function() dr = true; local mx = UIS:GetMouseLocation().X; local ax = bg.AbsolutePosition.X; local aw = bg.AbsoluteSize.X; if aw <= 0 then return end; local rx = math.clamp(mx - ax, 0, aw); local np = rx / aw; cv = math.floor(min + (max - min) * np + 0.5); cv = math.clamp(cv, min, max); fl.Size = UDim2.new(np, 0, 1, 0); v.Text = tostring(cv) .. suf; pcall(cb, cv) end)
