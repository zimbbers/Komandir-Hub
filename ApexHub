    valueLabel.Parent = bg
    
    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(0, 60, 0, 4)
    sliderBg.Position = UDim2.new(0, 210, 0.5, -2)
    sliderBg.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
    sliderBg.Parent = bg
    
    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new((Settings.Aimbot.FOV - min) / (max - min), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
    sliderFill.Parent = sliderBg
    
    -- Simplified slider logic
    local dragging = false
    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)
    sliderBg.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    RunService.RenderStepped:Connect(function()
        if dragging then
            local pos = UserInputService:GetMouseLocation()
            local absPos = sliderBg.AbsolutePosition
            local absSize = sliderBg.AbsoluteSize
            local relX = math.clamp((pos.X - absPos.X) / absSize.X, 0, 1)
            local val = math.floor(min + (max - min) * relX)
            
            -- Apply to correct setting
            local t = Settings
            if path then
                for _, p in ipairs(path) do
                    t = t[p]
                end
            end
            t[setting] = val
            valueLabel.Text = tostring(val)
            sliderFill.Size = UDim2.new(relX, 0, 1, 0)
        end
    end)
end

