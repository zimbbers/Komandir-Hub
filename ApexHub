local function CreateToggle(parent, name, setting, path, yPos)
    local toggles = Settings
    if path then
        for _, p in ipairs(path) do
            toggles = toggles[p]
        end
    end
    
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, 280, 0, 30)
    bg.Position = UDim2.new(0, 10, 0, yPos)
    bg.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
    bg.BackgroundTransparency = 1
    bg.Parent = parent
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 200, 1, 0)
    label.Text = name
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = bg
    
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 50, 0, 22)
    toggle.Position = UDim2.new(0, 210, 0.5, -11)
    toggle.Text = toggles[setting] and "ON" or "OFF"
    toggle.TextColor3 = toggles[setting] and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 50, 50)
    toggle.BackgroundColor3 = Color3.fromRGB(45, 45, 60)
    toggle.Font = Enum.Font.GothamBold
    toggle.TextSize = 11
    toggle.Parent = bg
    
    toggle.MouseButton1Click:Connect(function()
        if path then
            local t = Settings
            for _, p in ipairs(path) do
                t = t[p]
            end
            t[setting] = not t[setting]
            toggle.Text = t[setting] and "ON" or "OFF"
            toggle.TextColor3 = t[setting] and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 50, 50)
        else
            Settings[setting] = not Settings[setting]
            toggle.Text = Settings[setting] and "ON" or "OFF"
            toggle.TextColor3 = Settings[setting] and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 50, 50)
        end
    end)
    
    return bg
end

