local function FindEconomyRemotes()
    local EconomyRemotes = {}
    for _, Service in pairs(game:GetChildren()) do
        for _, obj in pairs(Service:GetDescendants()) do
            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                local n = obj.Name:lower()
                if n:find("money") or n:find("cash") or n:find("buy") or n:find("purchase") or
                   n:find("shop") or n:find("upgrade") or n:find("currency") or n:find("give") or
                   n:find("trade") or n:find("sell") or n:find("skin") or n:find("cosmetic") then
                    table.insert(EconomyRemotes, obj)
                end
            end
        end
    end
    return EconomyRemotes
end

