-- ========== ПОЛУЧЕНИЕ БЛИЖАЙШЕЙ ЦЕЛИ ==========
local function GetTarget()
    local closest = nil
    local closestDist = Config.Aimbot.FOV
    local mPos = UIS:GetMouseLocation()
    
    for _,plr in ipairs(P:GetPlayers()) do
        if plr == LP then continue end
        local char = plr.Character
        if not char then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not root or not hum or hum.Health <= 0 then continue end
        
        if Config.Aimbot.TeamCheck and plr.Team == LP.Team then continue end
        
        if Config.Aimbot.WallCheck then
            local ray = Ray.new(Cam.CFrame.Position, (root.Position - Cam.CFrame.Position).Unit * 1000)
            local hit = workspace:FindPartOnRayWithIgnoreList(ray, {LP.Character})
            if hit and not hit:IsDescendantOf(char) then continue end
        end
        
        local sp, onSc = Cam:WorldToViewportPoint(root.Position)
        if onSc then
            local dist = (V2(sp.X, sp.Y) - mPos).Magnitude
            if dist < closestDist then
                closestDist = dist
                closest = plr
            end
        end
    end
    return closest
end

-- ========== SKIN CHANGER ==========
local function ChangeSkins()
    if not Config.Skin.Enabled then return end
    local char = LP.Character
    if not char then return end
    
    for _,tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            local skin = Config.Skin.Skins[tool.Name]
            if skin then
                local handle = tool:FindFirstChild("Handle")
                if handle then
                    pcall(function()
                        local mesh = handle:FindFirstChildOfClass("SpecialMesh") or handle:FindFirstChild("Mesh")
                        if mesh then
                            -- Меняем цвет под скин (клиент-сайд)
                            local r = mRand(80, 255) / 255
                            local g = mRand(80, 255) / 255
                            local b = mRand(80, 255) / 255
                            mesh.VertexColor = V3(r, g, b)
                        end
                        
                        -- Пытаемся поменять текстуру скина
                        local tex = handle:FindFirstChild("Texture")
                        if tex then
                            -- Симуляция скина через изменение цвета
                            tex.Color3 = CI(mRand(50, 255), mRand(50, 255), mRand(50, 255))
                        end
                    end)
                end
            end
        end
    end
end

