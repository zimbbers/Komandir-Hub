-- FUNCTIONS
local function GetClosest(fov)
    local closest, shortest = nil, fov or 360
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("Head") then
            if C.Aim.Team and p.Team == LP.Team then continue end
            local sp, on = Camera:WorldToViewportPoint(p.Character.Head.Position)
            if not on then continue end
            local mp = UIS:GetMouseLocation()
            local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
            if d < shortest then shortest = d; closest = p end
        end
    end
    return closest
end

local silentRemote, silentHooked = nil, false
for _, o in pairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
    if o:IsA("RemoteEvent") then
        local n = o.Name:lower()
        if n:find("fire") or n:find("shoot") or n:find("bullet") then silentRemote = o; break end
    end
end

-- AIMBOT
RunSvc.RenderStepped:Connect(function()
    if _G.Apex_Aimbot and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local t = GetClosest(C.FOV)
        if t and t.Character and t.Character:FindFirstChild(C.Aim.Part) then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, t.Character[C.Aim.Part].Position), C.Smooth)
        end
    end
end)

-- SILENT AIM
if silentRemote then
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    local oldNC = mt.__namecall
    mt.__namecall = function(self, ...)
        local m = getnamecallmethod()
        local a = {...}
        if m == "FireServer" and self == silentRemote and _G.Apex_Silent then
            local t = GetClosest(360)
            if t and t.Character and t.Character:FindFirstChild(C.Aim.Part) then
                a[#a] = (t.Character[C.Aim.Part].Position - LP.Character.Head.Position).Unit
                return oldNC(self, unpack(a))
            end
        end
        return oldNC(self, ...)
    end
    setreadonly(mt, true)
    silentHooked = true
end

-- TRIGGERBOT
RunSvc.RenderStepped:Connect(function()
    if _G.Apex_Trigger then
        local t = Mouse.Target
        if t then
            local p = Players:GetPlayerFromCharacter(t.Parent)
            if not p then p = Players:GetPlayerFromCharacter(t.Parent and t.Parent.Parent) end
            if p and p ~= LP then
                if C.Aim.Team and p.Team == LP.Team then return end
                if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                    if (t.Position - LP.Character.HumanoidRootPart.Position).Magnitude <= C.TrigDist then
                        mouse1click(); task.wait(C.TrigRate)
                    end
                end
            end
        end
    end
end)

-- ESP
local ESP = {}
RunSvc.RenderStepped:Connect(function()
    for _, p in pairs(Players:GetPlayers()) do
        if p == LP then continue end
        if not ESP[p] then
            ESP[p] = {
                Box = Drawing.new("Square"), Health = Drawing.new("Square"),
                Name = Drawing.new("Text"), Tracer = Drawing.new("Line")
            }
            ESP[p].Box.Thickness = 2; ESP[p].Box.Filled = false
            ESP[p].Health.Filled = true
            ESP[p].Name.Size = 13; ESP[p].Name.Center = true; ESP[p].Name.Outline = true
            ESP[p].Tracer.Thickness = 1
        end
        local d = ESP[p]; local c = p.Character; local r = c and c:FindFirstChild("HumanoidRootPart"); local h = c and c:FindFirstChild("Humanoid")
        local show = false
        if r and h and h.Health > 0 then
            if C.ESPTeam and p.Team == LP.Team then
            else
                local sp, on = Camera:WorldToViewportPoint(c.Head.Position)
                if on then
                    show = true; local s = (Camera.CFrame.Position - r.Position).Magnitude / 500
                    local sz = Vector2.new(40/s, 60/s)
                    if _G.Apex_Box then
                        d.Box.Size = sz; d.Box.Position = Vector2.new(sp.X - sz.X/2, sp.Y - sz.Y/2)
                        d.Box.Color = Color3.fromRGB(0,255,0); d.Box.Visible = true
                    else d.Box.Visible = false end
                    if _G.Apex_Health and h then
                        local hp = h.Health / h.MaxHealth
                        d.Health.Size = Vector2.new(4, 60/s); d.Health.Position = Vector2.new(sp.X + sz.X/2 + 3, sp.Y - 30/s)
                        d.Health.Color = Color3.fromRGB(255*(1-hp), 255*hp, 0); d.Health.Visible = true
                    else d.Health.Visible = false end
                    if _G.Apex_Name then
                        d.Name.Position = Vector2.new(sp.X, sp.Y - sz.Y/2 - 15)
                        d.Name.Text = p.Name; d.Name.Color = Color3.new(1,1,1); d.Name.Visible = true
                    else d.Name.Visible = false end
                    if _G.Apex_Tracer then
                        d.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                        d.Tracer.To = Vector2.new(sp.X, sp.Y); d.Tracer.Color = Color3.new(1,1,1); d.Tracer.Visible = true
                    else d.Tracer.Visible = false end
                end
            end
        end
        if not show then d.Box.Visible = false; d.Health.Visible = false; d.Name.Visible = false; d.Tracer.Visible = false end
    end
end)

