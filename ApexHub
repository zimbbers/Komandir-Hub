    DropBtn.TextColor3 = ApexHub.Theme.Text
    DropBtn.TextSize = 13
    DropBtn.Font = Enum.Font.Gotham
    DropBtn.TextTruncate = Enum.TextTruncate.AtEnd
    DropBtn.AutoButtonColor = false
    
    local DB_Corner = Instance.new("UICorner")
    DB_Corner.CornerRadius = UDim.new(0, 4)
    DB_Corner.Parent = DropBtn
    
    -- Dropdown list
    local DropList = Instance.new("Frame")
    DropList.Size = UDim2.new(0.5, -10, 0, #Options * 26 + 4)
    DropList.Position = UDim2.new(0.5, 0, 0, 30)
    DropList.BackgroundColor3 = ApexHub.Theme.Topbar
    DropList.BackgroundTransparency = 0.1
    DropList.Visible = false
    DropList.ZIndex = 10
    
    local DL_Corner = Instance.new("UICorner")
    DL_Corner.CornerRadius = UDim.new(0, 4)
    DL_Corner.Parent = DropList
    
    local DropLayout = Instance.new("UIListLayout")
    DropLayout.Padding = UDim.new(0, 2)
    DropLayout.SortOrder = Enum.SortOrder.LayoutOrder
    DropLayout.Parent = DropList
    
    for _, opt in pairs(Options) do
        local OptBtn = Instance.new("TextButton")
        OptBtn.Size = UDim2.new(1, -8, 0, 24)
        OptBtn.Position = UDim2.new(0, 4, 0, 2)
        OptBtn.BackgroundTransparency = 0.8
        OptBtn.Text = opt
        OptBtn.TextColor3 = ApexHub.Theme.Text
        OptBtn.TextSize = 12
        OptBtn.Font = Enum.Font.Gotham
        OptBtn.AutoButtonColor = false
        OptBtn.ZIndex = 11
        
        OptBtn.MouseButton1Click:Connect(function()
            ApexHub.Flags[Flag] = opt
            DropBtn.Text = opt
            DropList.Visible = false
            pcall(Callback, opt)
        end)
        
        local O_Corner = Instance.new("UICorner")
        O_Corner.CornerRadius = UDim.new(0, 3)
        O_Corner.Parent = OptBtn
        OptBtn.Parent = DropList
    end
    
    DropBtn.MouseButton1Click:Connect(function()
        DropList.Visible = not DropList.Visible
    end)
    
    -- Закрытие при клике вне
    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            task.wait()
            if DropList.Visible then
                local mPos = UserInputService:GetMouseLocation()
                local absPos = DropList.AbsolutePosition
                local absSize = DropList.AbsoluteSize
                if mPos.X < absPos.X or mPos.X > absPos.X + absSize.X or
                   mPos.Y < absPos.Y or mPos.Y > absPos.Y + absSize.Y then
                    DropList.Visible = false
                end
            end
        end
    end)
    
    DropBtn.Parent = Frame
    DropList.Parent = Frame
    Frame.Parent = Parent
    
    return Frame
end

