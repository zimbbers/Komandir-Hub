                if not hl then hl = Instance.new("Highlight", t); hl.Name = "_HL" end
                hl.FillColor = Color3.fromRGB(255,215,0); hl.FillTransparency = 0.5; hl.Enabled = true
                local h = t:FindFirstChild("Handle")
                if h then h.Color = Color3.fromRGB(255,200,50); h.Material = Enum.Material.ForceField end
            end
        end
    end
    warn("[ApexHub] Skin applied (local)")
end)
Button(T_Skin, "Reset Skin", function()
    local function resetChar(char)
        for _, t in pairs(char:GetChildren()) do
            if t:IsA("Tool") then
                local hl = t:FindFirstChild("_HL"); if hl then hl:Destroy() end
                local h = t:FindFirstChild("Handle")
                if h then h.Color = Color3.new(1,1,1); h.Material = Enum.Material.Plastic end
            end
        end
    end
    if LP.Character then resetChar(LP.Character) end
    local bp = LP:FindFirstChild("Backpack")
    if bp then resetChar(bp) end
    warn("[ApexHub] Skin reset")
end)

