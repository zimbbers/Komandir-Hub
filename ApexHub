local function Slider(parent, name, min, max, def, cb, suffix)
    suffix = suffix or ""
    local f = Instance.new("Frame", parent)
    f.Size = UDim2.new(1, -4, 0, 44)
    f.BackgroundColor3 = Color3.fromRGB(40,40,55)
    f.BackgroundTransparency = 0.3
    Instance.new("UICorner", f).CornerRadius = UDim.new(0,4)
    
    local lbl = Instance.new("TextLabel", f)
    lbl.Size = UDim2.new(0.7, -6, 0, 20)
    lbl.Position = UDim2.new(0, 8, 0, 3)
    lbl.BackgroundTransparency = 1
    lbl.Text = name
    lbl.TextColor3 = Color3.fromRGB(220,220,220)
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Font = Enum.Font.Gotham
    
    local val = Instance.new("TextLabel", f)
    val.Size = UDim2.new(0.3, -6, 0, 20)
    val.Position = UDim2.new(0.7, 0, 0, 3)
    val.BackgroundTransparency = 1
    val.Text = tostring(def) .. suffix
    val.TextColor3 = Color3.fromRGB(0,170,255)
    val.TextSize = 13
    val.TextXAlignment = Enum.TextXAlignment.Right
    val.Font = Enum.Font.GothamBold
    
    local bg = Instance.new("Frame", f)
    bg.Size = UDim2.new(1, -16, 0, 6)
    bg.Position = UDim2.new(0, 8, 0, 30)
    bg.BackgroundColor3 = Color3.fromRGB(60,60,80)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0,3)
    
    local fill = Instance.new("Frame", bg)
    local pct = (def - min) / (max - min)
    fill.Size = UDim2.new(pct, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0,170,255)
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0,3)
    
    local hit = Instance.new("TextButton", bg)
    hit.Size = UDim2.new(1, 0, 1, 0)
    hit.BackgroundTransparency = 1
    hit.Text = ""
    
    local dragging = false
    local cval = def
    hit.MouseButton1Down:Connect(function()
        dragging = true
        local mx = UIS:GetMouseLocation().X
        local ax = bg.AbsolutePosition.X
        local aw = bg.AbsoluteSize.X
        if aw <= 0 then return end
        local rx = math.clamp(mx - ax, 0, aw)
        local np = rx / aw
        cval = math.floor(min + (max - min) * np + 0.5)
        cval = math.clamp(cval, min, max)
        fill.Size = UDim2.new(np, 0, 1, 0)
        val.Text = tostring(cval) .. suffix
        pcall(cb, cval)
    end)
    
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    
    RunSvc.RenderStepped:Connect(function()
        if dragging then
            local mx = UIS:GetMouseLocation().X
            local ax = bg.AbsolutePosition.X
            local aw = bg.AbsoluteSize.X
            if aw <= 0 then return end
            local rx = math.clamp(mx - ax, 0, aw)
            local np = rx / aw
            cval = math.floor(min + (max - min) * np + 0.5)
            cval = math.clamp(cval, min, max)
            fill.Size = UDim2.new(np, 0, 1, 0)
            val.Text = tostring(cval) .. suffix
            pcall(cb, cval)
        end
    end)
    return f
end

