local function FindShootRemote()
    for _, obj in pairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            local n = obj.Name:lower()
            if n:find("fire") or n:find("shoot") or n:find("bullet") or n:find("hit") then
                return obj
            end
        end
    end
    return nil
end

local ShootRemote = FindShootRemote()
if ShootRemote then
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    local oldNamecall = mt.__namecall
    mt.__namecall = function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if method == "FireServer" and self == ShootRemote and Config.SilentAim.Enabled then
            local Target = GetClosestPlayer()
            if Target and Target.Character and Target.Character:FindFirstChild(Config.SilentAim.TargetPart) then
                local TargetPos = Target.Character[Config.SilentAim.TargetPart].Position
                local Dir = (TargetPos - LocalPlayer.Character.Head.Position).Unit
                args[#args] = Dir
                return oldNamecall(self, unpack(args))
            end
        end
        
        return oldNamecall(self, ...)
    end
    setreadonly(mt, true)
end

