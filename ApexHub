-- Удалённая функция для вызовов (CommF_)
local function RemoteInvoke(...)
    local args = {...}
    return ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("CommF_"):InvokeServer(unpack(args))
end

-- Проверка на наличие персонажа
local function getChar()
    return LocalPlayer.Character
end

local function getHRP()
    local char = getChar()
    if char then
        return char:FindFirstChild("HumanoidRootPart")
    end
end

local function getHumanoid()
    local char = getChar()
    if char then
        return char:FindFirstChildOfClass("Humanoid")
    end
end

-- ==================== АВТОФАРМ (УРОВНИ / КВЕСТЫ) ====================

local function findClosestMob()
    local hrp = getHRP()
    if not hrp then return nil end
    local closest, dist = nil, math.huge
    for _, mob in pairs(workspace:FindFirstChild("Enemies"):GetChildren()) do
        if mob:FindFirstChild("HumanoidRootPart") and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
            local d = (mob.HumanoidRootPart.Position - hrp.Position).magnitude
            if d < dist then
                dist = d
                closest = mob
            end
        end
    end
    return closest
end

local function attackMob(mob)
    if not mob then return end
    local hrp = getHRP()
    if not hrp then return end
    -- Телепортируемся поближе
    hrp.CFrame = mob.HumanoidRootPart.CFrame * CFrame.new(0, 5, 0)
    -- Наносим урон (можно использовать мышь, но проще использовать удалённую функцию атаки, если есть)
    -- В Blox Fruits атака происходит через экипированное оружие. Мы просто будем нажимать кнопку мыши.
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
    task.wait(0.1)
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
end

local function autoFarmLoop()
    while Toggles.AutoFarm do
        local mob = findClosestMob()
        if mob then
            attackMob(mob)
        end
        task.wait(0.1)
    end
end

