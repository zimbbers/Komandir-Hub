local ESPObjects = {}

local function CreateESP(Player)
    if ESPObjects[Player] then return end
    
    local Box = Drawing.new("Square")
    Box.Visible = false; Box.Color = Color3.fromRGB(0, 255, 0); Box.Thickness = 2; Box.Filled = false
    
    local HealthBar = Drawing.new("Square")
    HealthBar.Visible = false; HealthBar.Color = Color3.fromRGB(0, 255, 0); HealthBar.Filled = true
    
    local NameTag = Drawing.new("Text")
    NameTag.Visible = false; NameTag.Size = 14; NameTag.Center = true; NameTag.Outline = true
    NameTag.Color = Color3.fromRGB(255, 255, 255)
    
    local TracerLine = Drawing.new("Line")
    TracerLine.Visible = false; TracerLine.Color = Color3.fromRGB(255, 255, 255); TracerLine.Thickness = 1
    
    ESPObjects[Player] = { Box = Box, HealthBar = HealthBar, NameTag = NameTag, Tracer = TracerLine }
end

local function UpdateESP()
    for _, Player in pairs(Players:GetPlayers()) do
        if Player == LocalPlayer then continue end
        if not ESPObjects[Player] then CreateESP(Player) end
        
        local ESPData = ESPObjects[Player]
        local Character = Player.Character
        local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character and Character:FindFirstChild("Humanoid")
        
        local IsVisible = false
        
        if Config.ESP.TeamCheck and Player.Team == LocalPlayer.Team then
            -- skip teammates
        elseif RootPart and Humanoid and Humanoid.Health > 0 then
            local HeadPos = Character.Head.Position
            local ScreenPos, OnScreen = Camera:WorldToViewportPoint(HeadPos)
            
            if OnScreen then
                IsVisible = true
                local Scale = (Camera.CFrame.Position - RootPart.Position).Magnitude / 500
                local Size = Vector2.new(40 / Scale, 60 / Scale)
                
                if Config.ESP.Box then
                    ESPData.Box.Size = Size
                    ESPData.Box.Position = Vector2.new(ScreenPos.X - Size.X/2, ScreenPos.Y - Size.Y/2)
                    ESPData.Box.Visible = true
                end
                
                if Config.ESP.Health and Humanoid then
                    local HealthPercent = Humanoid.Health / Humanoid.MaxHealth
                    local BarHeight = 60 / Scale
                    ESPData.HealthBar.Size = Vector2.new(4, BarHeight)
                    ESPData.HealthBar.Position = Vector2.new(ScreenPos.X + Size.X/2 + 3, ScreenPos.Y - BarHeight/2)
                    ESPData.HealthBar.Color = Color3.fromRGB(255 * (1 - HealthPercent), 255 * HealthPercent, 0)
                    ESPData.HealthBar.Visible = true
                end
                
                if Config.ESP.Name then
                    ESPData.NameTag.Position = Vector2.new(ScreenPos.X, ScreenPos.Y - Size.Y/2 - 16)
                    ESPData.NameTag.Text = Player.Name
                    ESPData.NameTag.Visible = true
                end
                
                if Config.ESP.Tracer then
                    ESPData.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                    ESPData.Tracer.To = Vector2.new(ScreenPos.X, ScreenPos.Y)
                    ESPData.Tracer.Visible = true
                end
            end
        end
        
        if not IsVisible then
            ESPData.Box.Visible = false
            ESPData.HealthBar.Visible = false
            ESPData.NameTag.Visible = false
            ESPData.Tracer.Visible = false
        end
    end
end

RunService.RenderStepped:Connect(UpdateESP)

