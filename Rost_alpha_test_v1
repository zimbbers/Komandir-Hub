-- ===== ESP + Tool ESP =====
local function CreateESP(plr)
   if plr == LP then return end

   local function OnChar(char)
      local hl = Instance.new("Highlight")
      hl.FillColor = Color3.fromRGB(255, 80, 80)
      hl.OutlineColor = Color3.new(1,1,1)
      hl.FillTransparency = 0.45
      hl.OutlineTransparency = 0.1
      hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
      hl.Adornee = char
      hl.Parent = char
      table.insert(ESPHighlights, hl)

      -- Tool Text (Drawing)
      local txt = Drawing.new("Text")
      txt.Size = 14
      txt.Center = true
      txt.Outline = true
      txt.Color = Color3.new(1, 0.8, 0)
      txt.Font = Drawing.Fonts.Monospace

      Connections[char] = RS.RenderStepped:Connect(function()
         if not char or not char.Parent then txt:Remove() return end
         local hrp = char:FindFirstChild("HumanoidRootPart")
         if hrp then
            local pos, vis = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3.5, 0))
            txt.Position = Vector2.new(pos.X, pos.Y)
            local toolName = "No Tool"
            for _, child in pairs(char:GetChildren()) do
               if child:IsA("Tool") then toolName = child.Name break end
            end
            txt.Text = plr.Name .. " | " .. toolName
            txt.Visible = vis and States.ToolESP
         end
      end)
   end

   if plr.Character then OnChar(plr.Character) end
   plr.CharacterAdded:Connect(OnChar)
end

