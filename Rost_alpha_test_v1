local function ClosestPlayerToMouse(fov)
   local closest, closestDist = nil, fov
   for _, plr in ipairs(plrs:GetPlayers()) do
      if plr ~= lp and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
         local screenPos, onScreen = cam:WorldToScreenPoint(plr.Character.Head.Position)
         if onScreen then
            local dist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
            if dist < closestDist then
               closest = plr
               closestDist = dist
            end
         end
      end
   end
   return closest
end

local silentAim = true -- toggle from GUI
local fov = 100 -- slider from GUI
local snapline = true
local noRecoil = true
