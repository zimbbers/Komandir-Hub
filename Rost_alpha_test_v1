-- ===== VERYUP RAGE (Silent Aim/Magic Bullets/No Recoil - Open Source Adapted) =====
local VeryUpSilent = false
local VeryUpFOV = 120
local VeryUpSnapline = false
local VeryUpNoRecoil = false
local VeryUpMagic = false
local SnapLine = Drawing.new("Line")
SnapLine.Color = Color3.new(1,0,0)
SnapLine.Thickness = 2
SnapLine.Visible = false

local function ClosestInFOV(fov)
   local closest, d = nil, fov
   local mouse = Vector2.new(LocalPlayer:GetMouse().X, LocalPlayer:GetMouse().Y)
   for _, plr in pairs(Players:GetPlayers()) do
      if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") and plr.Character.Humanoid.Health > 0 then
         local screen, onScreen = Camera:WorldToViewportPoint(plr.Character.Head.Position)
         if onScreen then
            local dist = (Vector2.new(screen.X, screen.Y) - mouse).Magnitude
            if dist < d then closest = plr; d = dist end
         end
      end
   end
   return closest
end

-- Magic Bullets Hook (Through Walls - Headshot)
local mt = getrawmetatable(game)
local oldNC = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
   local args = {...}
   local method = getnamecallmethod()
   if VeryUpMagic and method == "FireServer" and (self.Name:find("Gun") or self.Name:find("Shoot") or self.Name:find("Remote")) then
      local closest = ClosestInFOV(VeryUpFOV)
      if closest and closest.Character.Head then args[1] = closest.Character.Head.Position end
   end
   return oldNC(self, unpack(args))
end)
setreadonly(mt, true)

