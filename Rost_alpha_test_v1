      print("Speed now: " .. Speed)
   end
end)

-- ===== ESP RESOURCES (Chests/Beds/Cabinets/Stones) =====
local function UpdateResourceESP()
   for _, obj in pairs(workspace:GetDescendants()) do
      local name = obj.Name:lower()
      if name:find("chest") or name:find("sunduk") or name:find("bed") or name:find("spalnik") or name:find("cabinet") or name:find("shkaf") or name:find("stone") or name:find("rock") or name:find("ore") then
         if not obj:FindFirstChild("ResourceESP") then
            local hl = Instance.new("Highlight")
            hl.Name = "ResourceESP"
            hl.FillColor = Color3.new(0,1,0)
            hl.OutlineColor = Color3.new(1,1,1)
            hl.FillTransparency = 0.6
            hl.OutlineTransparency = 0
            hl.Parent = obj

            local text = Drawing.new("Text")
            text.Size = 14
            text.Outline = true
            text.Color = Color3.new(0,1,0)
            text.Center = true

            Connections[obj] = RunService.RenderStepped:Connect(function()
               local pos, vis = Camera:WorldToViewportPoint(obj.Position)
               text.Position = Vector2.new(pos.X, pos.Y)
               text.Text = obj.Name
               text.Visible = vis
            end)

            table.insert(ESPObjects, hl)
         end
      end
   end
end

-- ===== HOTKEYS =====
UIS.InputBegan:Connect(function(input)
   if input.KeyCode == Enum.KeyCode.G then God = not God; print("God: " .. tostring(God)) end
   if input.KeyCode == Enum.KeyCode.N then Noclip = not Noclip; print("Noclip: " .. tostring(Noclip)) end
   if input.KeyCode == Enum.KeyCode.F then ToggleFly(); print("Fly: " .. tostring(Fly)) end
   if input.KeyCode == Enum.KeyCode.V then Speed = Speed == 16 and 40 or 16; print("Speed: " .. Speed) end
   if input.KeyCode == Enum.KeyCode.M then MagicBullets = not MagicBullets; print("Magic Bullets: " .. tostring(MagicBullets)) end
   if input.KeyCode == Enum.KeyCode.E then
      ESPResources = not ESPResources
      if ESPResources then
         Connections.ESP = RunService.Heartbeat:Connect(UpdateResourceESP)
      else
         if Connections.ESP then Connections.ESP:Disconnect() end
         for _, hl in pairs(ESPObjects) do hl:Destroy() end
         ESPObjects = {}
      end
      print("ESP Resources: " .. tostring(ESPResources))
   end
end)

