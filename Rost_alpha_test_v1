-- ===== PLAYER ESP (HIGHLIGHT + TOOL ESP) =====
local function AddPlayerESP(plr)
   if plr == LocalPlayer then return end
   plr.CharacterAdded:Connect(function(char)
      local hl = Instance.new("Highlight")
      hl.FillColor = Color3.new(1,0,0)
      hl.OutlineColor = Color3.new(1,1,1)
      hl.Parent = char
      table.insert(Highlights, hl)
      -- Tool ESP
      local text = Drawing.new("Text")
      Connections[plr] = RunService.RenderStepped:Connect(function()
         local hrp = char:FindFirstChild("HumanoidRootPart")
         if hrp then
            local pos, vis = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0,3,0))
            text.Position = Vector2.new(pos.X, pos.Y)
            local tool = "No Tool"
            for _, t in pairs(char:GetChildren()) do if t:IsA("Tool") then tool = t.Name end end
            text.Text = plr.Name .. " [" .. tool .. "]"
            text.Visible = vis
         end
      end)
   end)
end

for _, plr in pairs(Players:GetPlayers()) do AddPlayerESP(plr) end
