-- Rost Alpha FIX 2026 | Low-Detect God + Noclip + Fly + Speed (no kick) + ESP + Silent Aim base
-- Respawn FIRST! | Xeno/Solara | Execute → Respawn → Test one by one

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local LP = Players.LocalPlayer

local God = false
local Noclip = false
local Fly = false
local Speed = 16  -- start low, max ~40-50 to avoid kick
local ESPOn = false

local ESPTable = {}

-- ===== GOD MODE FIX (regen loop + hook health, no math.huge) =====
local GodConn
local function ToggleGod(val)
    God = val
    if God then
        GodConn = RunService.Heartbeat:Connect(function()
            if LP.Character and LP.Character:FindFirstChild("Humanoid") then
                local h = LP.Character.Humanoid
                if h.Health < h.MaxHealth then
                    h.Health = h.MaxHealth  -- regen instead of huge
                end
                h.MaxHealth = 100  -- keep normal to avoid detect
            end
        end)
    else
        if GodConn then GodConn:Disconnect() end
    end
end

-- ===== NOCLIP FIX (Stepped + only on toggle, reset on disable) =====
local NoclipConn
local function ToggleNoclip(val)
    Noclip = val
    if Noclip then
        NoclipConn = RunService.Stepped:Connect(function()
            if LP.Character then
                for _, p in pairs(LP.Character:GetDescendants()) do
                    if p:IsA("BasePart") then
                        p.CanCollide = false
                    end
                end
            end
        end)
    else
        if NoclipConn then NoclipConn:Disconnect() end
        -- Reset collides to avoid visual bugs
        if LP.Character then
            for _, p in pairs(LP.Character:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.CanCollide = true
                end
            end
        end
    end
end

-- ===== FLY FIX (CFrame based, low detect) =====
local FlySpeed = 40  -- low to avoid kick
local FlyConn
local function ToggleFly(val)
    Fly = val
    if Fly then
        FlyConn = RunService.RenderStepped:Connect(function()
            if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = LP.Character.HumanoidRootPart
                local move = Vector3.new(0,0,0)
                if UIS:IsKeyDown(Enum.KeyCode.W) then move += Camera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.S) then move -= Camera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.A) then move -= Camera.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.D) then move += Camera.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0,1,0) end
                if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then move -= Vector3.new(0,1,0) end
                hrp.CFrame = hrp.CFrame + (move * FlySpeed * 0.016)  -- delta time safe
            end
        end)
    else
        if FlyConn then FlyConn:Disconnect() end
    end
end

-- ===== SPEED FIX (low value + no extreme) =====
local function SetSpeed(val)
    Speed = val
    if LP.Character and LP.Character:FindFirstChild("Humanoid") then
        LP.Character.Humanoid.WalkSpeed = val
    end
end

-- ===== ESP (Highlight, low detect) =====
local function AddESP(plr)
    if plr == LP then return end
    local conn = plr.CharacterAdded:Connect(function(char)
        local hl = Instance.new("Highlight")
        hl.FillColor = Color3.fromRGB(255,50,50)
        hl.OutlineColor = Color3.new(1,1,1)
        hl.FillTransparency = 0.6
        hl.OutlineTransparency = 0
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Adornee = char
        hl.Parent = char
        table.insert(ESPTable, hl)
    end)
    if plr.Character then conn(plr.Character) end
end

local function ToggleESP(val)
    ESPOn = val
    if val then
        for _, plr in pairs(Players:GetPlayers()) do AddESP(plr) end
        Players.PlayerAdded:Connect(AddESP)
    else
        for _, hl in pairs(ESPTable) do hl:Destroy() end
        ESPTable = {}
    end
end

-- ===== SILENT AIM BASE (mouse target, very basic, low detect) =====
local function SilentAim()
    local mouse = LP:GetMouse()
    local target = mouse.Target
    if target and target.Parent and target.Parent:FindFirstChild("Humanoid") then
        -- Здесь можно добавить fire server или raycast hook, но для теста просто print
        print("Silent hit on: " .. target.Parent.Name)
        -- Для реального: hook __namecall на remote events оружия
    end
end

UIS.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        SilentAim()
    end
end)

-- ===== HOTKEYS =====
UIS.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.G then ToggleGod(not God) end
    if input.KeyCode == Enum.KeyCode.N then ToggleNoclip(not Noclip) end
    if input.KeyCode == Enum.KeyCode.F then ToggleFly(not Fly) end
    if input.KeyCode == Enum.KeyCode.V then
        local newSpeed = Speed == 16 and 40 or 16  -- safe values
        SetSpeed(newSpeed)
        print("Speed set to " .. newSpeed)
    end
    if input.KeyCode == Enum.KeyCode.E then ToggleESP(not ESPOn) end
end)

-- ===== CHARACTER ADDED (reset on respawn) =====
LP.CharacterAdded:Connect(function()
    wait(1)  -- wait load
    SetSpeed(Speed)
    if God then ToggleGod(true) end
    if Noclip then ToggleNoclip(true) end
    if Fly then ToggleFly(true) end
end)

print("Rost Alpha FIX Loaded! Respawn NOW!")
print("G=God, N=Noclip, F=Fly, V=Speed toggle, E=ESP")
print("Speed max 40 to avoid kick! Test one feature at a time.")
